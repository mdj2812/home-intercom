{
  "id": "4CCLNbj0pxRYJK0c",
  "name": "Intercom 播放",
  "description": "Flask回调触发：接收{entity, url} → 调用HA play_media播放音频",
  "active": true,
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "intercom/play",
        "responseMode": "onReceived",
        "options": {
          "noResponseBody": false
        }
      },
      "name": "Intercom Play",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "resource": "service",
        "operation": "call",
        "domain": "media_player",
        "service": "play_media",
        "serviceAttributes": {
          "attributes": [
            {
              "name": "entity_id",
              "value": "={{ $json.body.entity }}"
            },
            {
              "name": "media_content_id",
              "value": "={{ $json.body.url }}"
            },
            {
              "name": "media_content_type",
              "value": "music"
            }
          ]
        }
      },
      "name": "播放到音箱",
      "type": "n8n-nodes-base.homeAssistant",
      "typeVersion": 1,
      "position": [
        224,
        0
      ]
    }
  ],
  "connections": {
    "Intercom Play": {
      "main": [
        [
          {
            "node": "播放到音箱",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}